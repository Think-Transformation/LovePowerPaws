---
const campaignToken = import.meta.env.PUBLIC_GETRESPONSE_CAMPAIGN_TOKEN ?? '';
const thankYouUrl = new URL('/thanks/', Astro.site).href;
const showTokenWarning = !campaignToken;
---

<section id="subscribe" class="scroll-mt-20 border-t border-lp-mint-strong/90 bg-lp-mint/35 py-16 sm:py-20">
	<div class="mx-auto max-w-6xl px-4 sm:px-6">
		<div class="grid gap-10 lg:grid-cols-2 lg:gap-16 lg:items-start">
			<div>
				<h2 class="font-display text-3xl font-semibold tracking-tight text-lp-ink sm:text-4xl">
					Get booth updates
				</h2>
				<p class="mt-3 text-lp-slate">
					Join the mailing list for news about Love Power Paws at The Shed — schedules, specials, and what we’re
					bringing to booth <strong>#6113</strong>.
				</p>
				<p class="mt-4 text-sm text-lp-slate/85">
					We use GetResponse to send updates. You can unsubscribe anytime from messages you receive.
				</p>
			</div>

			<div class="rounded-2xl border border-lp-mint-strong/90 bg-white p-6 shadow-sm sm:p-8">
				{
					showTokenWarning ? (
						<div class="mb-6 rounded-xl border border-lp-ginger/50 bg-lp-mint px-4 py-3 text-sm text-lp-ink">
							<p class="font-medium">Action needed</p>
							<p class="mt-1 text-lp-slate">
								Set <code class="rounded bg-white/80 px-1">PUBLIC_GETRESPONSE_CAMPAIGN_TOKEN</code> in{' '}
								<code class="rounded bg-white/80 px-1">.env</code> (local) and in GitHub Actions secrets
								(see README) so subscriptions reach your list.
							</p>
						</div>
					) : null
				}

				<form
					action="https://app.getresponse.com/add_subscriber.html"
					accept-charset="utf-8"
					method="post"
					class="space-y-4"
				>
					<div>
						<label for="gr-email" class="block text-sm font-medium text-lp-ink">
							Email <span class="text-red-600">*</span>
						</label>
						<input
							id="gr-email"
							type="email"
							name="email"
							required
							autocomplete="email"
							placeholder="you@example.com"
							class="mt-1.5 w-full rounded-xl border border-lp-mint-strong bg-white px-3 py-2.5 text-lp-ink shadow-sm outline-none ring-lp-teal/0 transition focus:border-lp-teal focus:ring-4 focus:ring-lp-teal/25"
						/>
					</div>
					<div>
						<label for="gr-name" class="block text-sm font-medium text-lp-ink">Name (optional)</label>
						<input
							id="gr-name"
							type="text"
							name="name"
							autocomplete="name"
							placeholder="Your name"
							class="mt-1.5 w-full rounded-xl border border-lp-mint-strong bg-white px-3 py-2.5 text-lp-ink shadow-sm outline-none ring-lp-teal/0 transition focus:border-lp-teal focus:ring-4 focus:ring-lp-teal/25"
						/>
					</div>

					<input type="hidden" name="campaign_token" value={campaignToken} />
					<input type="hidden" name="thankyou_url" value={thankYouUrl} />
					<input type="hidden" name="start_day" value="0" />

					<button
						type="submit"
						class="w-full rounded-xl bg-lp-orange px-4 py-3 text-center text-sm font-semibold text-white shadow-sm transition hover:brightness-95 focus:outline-none focus-visible:ring-4 focus-visible:ring-lp-purple/35"
					>
						Subscribe
					</button>
				</form>
			</div>
		</div>
	</div>
</section>
