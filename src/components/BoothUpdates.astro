---
type UpdateItem = { date: string; text: string };

type UpdatesFile = { items: UpdateItem[] };

type Props = {
	updates: UpdatesFile;
};

const { updates } = Astro.props;
const items = (updates.items ?? []).filter((i) => i.text?.trim());
---

{
	items.length > 0 ? (
		<section id="updates" class="scroll-mt-20 border-t border-lp-mint-strong/90 bg-lp-cream py-16 sm:py-20">
			<div class="mx-auto max-w-6xl px-4 sm:px-6">
				<h2 class="font-display text-3xl font-semibold tracking-tight text-lp-ink sm:text-4xl">
					Booth updates
				</h2>
				<ul class="mt-8 space-y-4">
					{items.map((item) => (
						<li class="rounded-2xl border border-lp-mint-strong/90 bg-white px-5 py-4 shadow-sm">
							<p class="text-xs font-semibold uppercase tracking-wide text-lp-purple">{item.date}</p>
							<p class="mt-2 text-lp-ink">{item.text}</p>
						</li>
					))}
				</ul>
			</div>
		</section>
	) : null
}
