---
type UpdateItem = { date: string; text: string };

type UpdatesFile = { items: UpdateItem[] };

type Props = {
	updates: UpdatesFile;
};

const { updates } = Astro.props;
const items = (updates.items ?? []).filter((i) => i.text?.trim());
---

{
	items.length > 0 ? (
		<section id="updates" class="scroll-mt-20 border-t border-stone-200/80 bg-stone-50 py-16 sm:py-20">
			<div class="mx-auto max-w-6xl px-4 sm:px-6">
				<h2 class="font-display text-3xl font-semibold tracking-tight text-stone-900 sm:text-4xl">
					Booth updates
				</h2>
				<p class="mt-3 max-w-2xl text-stone-600">
					Quick notes from the road. Edit{' '}
					<code class="rounded bg-white px-1.5 py-0.5 text-sm text-stone-800">src/content/updates.json</code>{' '}
					(or automate later via Slack → GitHub).
				</p>
				<ul class="mt-8 space-y-4">
					{items.map((item) => (
						<li class="rounded-2xl border border-stone-200/90 bg-white px-5 py-4 shadow-sm">
							<p class="text-xs font-semibold uppercase tracking-wide text-amber-800/90">{item.date}</p>
							<p class="mt-2 text-stone-800">{item.text}</p>
						</li>
					))}
				</ul>
			</div>
		</section>
	) : null
}
