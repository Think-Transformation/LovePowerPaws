---
import type { GalleryImage } from '../lib/gallery';

type Props = {
	images: GalleryImage[];
};

const { images } = Astro.props;
---

<section id="gallery" class="scroll-mt-20 border-t border-lp-mint-strong/90 bg-white py-16 sm:py-20">
	<div class="mx-auto max-w-6xl px-4 sm:px-6">
		<h2 class="font-display text-3xl font-semibold tracking-tight text-lp-ink sm:text-4xl">
			Gallery
		</h2>

		{
			images.length === 0 ? (
				<div class="mt-10 rounded-2xl border border-dashed border-lp-teal/40 bg-lp-mint/50 px-6 py-14 text-center text-lp-slate">
					<p class="font-medium text-lp-ink">No photos yet</p>
					<p class="mt-2 text-sm">
						Drop <span class="whitespace-nowrap">.jpg / .png / .webp</span> files into{' '}
						<code class="rounded bg-white px-1.5 py-0.5 text-lp-ink">public/gallery/</code> to
						fill this grid.
					</p>
				</div>
			) : (
				<ul class="mt-10 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
					{images.map((img, i) => (
						<li>
							<button
								type="button"
								class="gallery-thumb group relative block w-full overflow-hidden rounded-2xl border border-lp-mint-strong/90 bg-lp-mint/40 text-left shadow-sm transition hover:border-lp-teal hover:shadow-md focus:outline-none focus-visible:ring-2 focus-visible:ring-lp-teal-deep/70"
								data-gallery-index={i}
								aria-label={`Open larger view: ${img.alt}`}
							>
								<img
									src={img.src}
									alt={img.alt}
									loading="lazy"
									decoding="async"
									class="aspect-[4/3] w-full object-cover transition duration-300 group-hover:scale-[1.02]"
								/>
							</button>
						</li>
					))}
				</ul>
			)
		}

		<dialog
			id="gallery-lightbox"
			class="gallery-dialog fixed left-1/2 top-1/2 z-[100] max-h-[90vh] w-[min(96vw,56rem)] max-w-[min(96vw,56rem)] -translate-x-1/2 -translate-y-1/2 overflow-hidden rounded-2xl border border-white/25 bg-lp-teal p-0 text-white shadow-2xl"
		>
			<div class="flex items-center justify-end border-b border-white/20 px-3 py-2">
				<button
					type="button"
					class="gallery-lightbox-close rounded-lg px-3 py-1.5 text-sm font-semibold text-white/95 hover:bg-white/15 focus:outline-none focus-visible:ring-2 focus-visible:ring-white/70"
					onclick="this.closest('dialog')?.close()"
				>
					Close
				</button>
			</div>
			<div class="min-h-0 flex-1 overflow-auto p-4 sm:p-6">
				<img
					id="gallery-lightbox-img"
					src=""
					alt=""
					class="mx-auto max-h-[70vh] w-auto max-w-full rounded-lg object-contain shadow-lg ring-1 ring-white/35"
				/>
			</div>
		</dialog>
	</div>
</section>

<script is:inline>
	(function () {
		const dialog = document.getElementById('gallery-lightbox');
		const imgEl = document.getElementById('gallery-lightbox-img');
		if (!dialog || !imgEl || !('showModal' in dialog)) return;

		document.querySelectorAll('.gallery-thumb').forEach(function (btn) {
			btn.addEventListener('click', function () {
				const tile = btn.querySelector('img');
				if (!tile) return;
				imgEl.src = tile.currentSrc || tile.src;
				imgEl.alt = tile.alt;
				dialog.showModal();
			});
		});

		dialog.addEventListener('click', function (e) {
			if (e.target === dialog) dialog.close();
		});

		dialog.addEventListener('cancel', function () {
			dialog.close();
		});
	})();
</script>

<style>
	/* Native <dialog> must stay display:none when closed; Tailwind `flex` was forcing it visible. */
	.gallery-dialog:not([open]) {
		display: none;
	}

	.gallery-dialog[open] {
		display: flex;
		flex-direction: column;
	}

	/* Center in the top layer + dim behind the modal */
	.gallery-dialog::backdrop {
		background: rgb(22 32 42 / 0.55);
	}
</style>
