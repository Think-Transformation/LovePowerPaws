---
import type { GalleryImage } from '../lib/gallery';

type Props = {
	images: GalleryImage[];
};

const { images } = Astro.props;
---

<section id="gallery" class="scroll-mt-20 border-t border-lp-mint-strong/90 bg-white py-16 sm:py-20">
	<div class="mx-auto max-w-6xl px-4 sm:px-6">
		<h2 class="font-display text-3xl font-semibold tracking-tight text-lp-ink sm:text-4xl">
			Gallery
		</h2>
		<p class="mt-3 max-w-2xl text-lp-slate">
			New photos from the booth land here. Add images to <code class="rounded bg-lp-mint px-1.5 py-0.5 text-sm text-lp-ink">public/gallery/</code> and push to GitHub — the site rebuilds automatically.
		</p>

		{
			images.length === 0 ? (
				<div class="mt-10 rounded-2xl border border-dashed border-lp-teal/40 bg-lp-mint/50 px-6 py-14 text-center text-lp-slate">
					<p class="font-medium text-lp-ink">No photos yet</p>
					<p class="mt-2 text-sm">
						Drop <span class="whitespace-nowrap">.jpg / .png / .webp</span> files into{' '}
						<code class="rounded bg-white px-1.5 py-0.5 text-lp-ink">public/gallery/</code> to
						fill this grid.
					</p>
				</div>
			) : (
				<ul class="mt-10 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
					{images.map((img, i) => (
						<li>
							<button
								type="button"
								class="gallery-thumb group relative block w-full overflow-hidden rounded-2xl border border-lp-mint-strong/90 bg-lp-mint/40 text-left shadow-sm transition hover:border-lp-teal hover:shadow-md focus:outline-none focus-visible:ring-2 focus-visible:ring-lp-purple/60"
								data-gallery-index={i}
								aria-label={`Open larger view: ${img.alt}`}
							>
								<img
									src={img.src}
									alt={img.alt}
									loading="lazy"
									decoding="async"
									class="aspect-[4/3] w-full object-cover transition duration-300 group-hover:scale-[1.02]"
								/>
								<span class="absolute inset-x-0 bottom-0 bg-gradient-to-t from-lp-ink/75 to-transparent px-4 pb-3 pt-10 text-sm font-medium text-white">
									{img.alt}
								</span>
							</button>
						</li>
					))}
				</ul>
			)
		}

		<dialog
			id="gallery-lightbox"
			class="gallery-dialog max-h-[90vh] max-w-[min(96vw,56rem)] rounded-2xl border border-lp-mint-strong bg-lp-ink p-0 text-stone-50 shadow-2xl backdrop:bg-lp-ink/75 open:flex open:flex-col"
		>
			<form method="dialog" class="flex items-center justify-end border-b border-white/10 px-3 py-2">
				<button
					type="submit"
					class="rounded-lg px-3 py-1.5 text-sm font-medium text-stone-300 hover:bg-stone-800 hover:text-white"
				>
					Close
				</button>
			</form>
			<div class="min-h-0 flex-1 overflow-auto p-4 sm:p-6">
				<img id="gallery-lightbox-img" src="" alt="" class="mx-auto max-h-[70vh] w-auto max-w-full rounded-lg object-contain" />
				<p id="gallery-lightbox-caption" class="mt-4 text-center text-sm text-stone-300" />
			</div>
		</dialog>
	</div>
</section>

<script>
	const thumbs = document.querySelectorAll<HTMLButtonElement>('.gallery-thumb');
	const dialog = document.getElementById('gallery-lightbox') as HTMLDialogElement | null;
	const imgEl = document.getElementById('gallery-lightbox-img') as HTMLImageElement | null;
	const capEl = document.getElementById('gallery-lightbox-caption');

	if (dialog && imgEl && capEl) {
		thumbs.forEach((btn) => {
			btn.addEventListener('click', () => {
				const tile = btn.querySelector('img');
				if (!tile) return;
				imgEl.src = tile.currentSrc || tile.src;
				imgEl.alt = tile.alt;
				capEl.textContent = tile.alt;
				dialog.showModal();
			});
		});

		dialog.addEventListener('click', (e) => {
			const rect = dialog.getBoundingClientRect();
			const inDialog =
				e.clientX >= rect.left && e.clientX <= rect.right && e.clientY >= rect.top && e.clientY <= rect.bottom;
			if (!inDialog) dialog.close();
		});
	}
</script>

<style>
	.gallery-dialog::backdrop {
		background: rgb(22 32 42 / 0.72);
	}
</style>
