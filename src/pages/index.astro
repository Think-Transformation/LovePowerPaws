---
import Layout from '../layouts/Layout.astro';
import Gallery from '../components/Gallery.astro';
import GetResponseForm from '../components/GetResponseForm.astro';
import BoothUpdates from '../components/BoothUpdates.astro';
import { getGalleryImages } from '../lib/gallery';
import updates from '../content/updates.json';

const images = getGalleryImages();
---

<Layout title="Love Power Paws | Booth #6113 at The Shed">
	<a
		href="#main"
		class="sr-only focus:not-sr-only focus:absolute focus:left-4 focus:top-4 focus:z-50 focus:rounded-lg focus:bg-white focus:px-4 focus:py-2 focus:text-lp-ink focus:shadow-lg"
	>
		Skip to content
	</a>

	<header class="sticky top-0 z-40 border-b border-lp-mint-strong/90 bg-lp-cream/90 backdrop-blur-md">
		<div class="mx-auto flex max-w-6xl items-center justify-between gap-4 px-4 py-3 sm:px-6">
			<a href="/" class="flex shrink-0 items-center rounded-full ring-lp-teal/0 transition hover:ring-4 focus:outline-none focus-visible:ring-4 focus-visible:ring-lp-teal/35" aria-label="Love Power Paws home">
				<img src="/brand/logo-full.svg" width="176" height="176" class="h-10 w-10 sm:h-11 sm:w-11" alt="" decoding="async" />
			</a>
			<nav
				aria-label="Primary"
				class="flex flex-wrap items-center justify-end gap-x-4 gap-y-2 text-xs font-medium text-lp-slate sm:gap-x-6 sm:text-sm"
			>
				<a href="#updates" class="transition hover:text-lp-ink">Updates</a>
				<a href="#gallery" class="transition hover:text-lp-ink">Gallery</a>
				<a href="#about" class="transition hover:text-lp-ink">About</a>
				<a
					href="#subscribe"
					class="rounded-full bg-lp-purple px-3 py-1.5 text-white shadow-sm transition hover:bg-lp-purple-soft sm:px-4 sm:py-2"
				>
					Subscribe
				</a>
			</nav>
		</div>
	</header>

	<main id="main">
		<section class="relative overflow-hidden">
			<div
				class="pointer-events-none absolute -right-24 -top-24 h-72 w-72 rounded-full bg-lp-teal/35 blur-3xl"
				aria-hidden="true"
			/>
			<div
				class="pointer-events-none absolute -bottom-32 -left-24 h-80 w-80 rounded-full bg-lp-orange/25 blur-3xl"
				aria-hidden="true"
			/>

			<div class="mx-auto max-w-6xl px-4 pb-16 pt-14 sm:px-6 sm:pb-20 sm:pt-20">
				<p class="text-sm font-semibold uppercase tracking-wider text-lp-purple">The Shed</p>
				<h1 class="font-display mt-3 max-w-3xl text-4xl font-semibold leading-tight tracking-tight text-lp-ink sm:text-5xl lg:text-6xl">
					Visit us at booth <span class="text-lp-orange">#6113</span>
				</h1>
				<p class="mt-5 max-w-2xl text-lg text-lp-slate">
					Shop cat and dog home decor right at the booth — stickers and magnets made to look just like your pets,
					plus more pieces to dress up your space.
				</p>
				<div class="mt-8 flex flex-wrap gap-3">
					<a
						href="#gallery"
						class="inline-flex items-center justify-center rounded-xl bg-lp-ink px-5 py-3 text-sm font-semibold text-white shadow-sm transition hover:bg-lp-slate focus:outline-none focus-visible:ring-4 focus-visible:ring-lp-teal/40"
					>
						See the gallery
					</a>
					<a
						href="#subscribe"
						class="inline-flex items-center justify-center rounded-xl border border-lp-mint-strong bg-white px-5 py-3 text-sm font-semibold text-lp-ink shadow-sm transition hover:border-lp-teal hover:bg-lp-mint focus:outline-none focus-visible:ring-4 focus-visible:ring-lp-purple/25"
					>
						Email me updates
					</a>
				</div>
			</div>
		</section>

		<BoothUpdates updates={updates} />

		<Gallery images={images} />

		<section id="about" class="scroll-mt-20 border-t border-lp-mint-strong/90 bg-white py-16 sm:py-20">
			<div class="mx-auto max-w-6xl px-4 sm:px-6">
				<h2 class="font-display text-3xl font-semibold tracking-tight text-lp-ink sm:text-4xl">About</h2>
				<div class="mt-8 grid gap-10 lg:grid-cols-3 lg:gap-12">
					<div class="lg:col-span-2">
						<p class="text-lg text-lp-slate">
							Love Power Paws is a booth at The Shed where you can browse and buy pet-inspired decor for your
							home. Highlights include stickers and magnets designed to capture your cat or dog’s look — plus
							other finds for animal lovers, all available to purchase on the spot at <strong>booth #6113</strong>.
						</p>
						<p class="mt-4 text-lp-slate/90">
							Bookmark this page for new photos, product spotlights, and updates from the booth.
						</p>
					</div>
					<aside class="rounded-2xl border border-lp-mint-strong/90 bg-lp-mint/60 p-6">
						<h3 class="text-sm font-semibold uppercase tracking-wide text-lp-slate">At the booth</h3>
						<ul class="mt-4 space-y-3 text-lp-ink">
							<li class="flex gap-3">
								<span class="mt-1 h-2 w-2 shrink-0 rounded-full bg-lp-orange" aria-hidden="true" />
								<span>Find your pet with our sticker and magnet collection</span>
							</li>
							<li class="flex gap-3">
								<span class="mt-1 h-2 w-2 shrink-0 rounded-full bg-lp-teal-deep" aria-hidden="true" />
								<span>Take a seat in the petting chair and enjoy our robotic animals</span>
							</li>
							<li class="flex gap-3">
								<span class="mt-1 h-2 w-2 shrink-0 rounded-full bg-lp-purple" aria-hidden="true" />
								<span>Take in the smells of our amazing candles, wax melts, and soaps</span>
							</li>
						</ul>
					</aside>
				</div>
			</div>
		</section>

		<GetResponseForm />
	</main>

	<footer class="border-t border-stone-200/80 bg-stone-900 py-10 text-stone-300">
		<div class="mx-auto flex max-w-6xl flex-col gap-6 px-4 sm:flex-row sm:items-center sm:justify-between sm:px-6">
			<div>
				<p class="font-display text-lg font-semibold text-white">Love Power Paws</p>
				<p class="mt-1 text-sm text-stone-400">The Shed — booth #6113</p>
			</div>
			<p class="text-sm text-stone-400">
				<a href="#subscribe" class="text-lp-ginger underline-offset-4 hover:underline">Mailing list</a>
				<span class="mx-2 text-stone-600" aria-hidden="true">·</span>
				<a href="#gallery" class="text-lp-ginger underline-offset-4 hover:underline">Gallery</a>
			</p>
		</div>
	</footer>
</Layout>
