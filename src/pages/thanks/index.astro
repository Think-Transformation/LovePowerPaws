---
import Layout from '../../layouts/Layout.astro';
---

<Layout
	title="Thanks for subscribing | Love Power Paws"
	description="You’re on the list for Love Power Paws booth updates at The Shed."
>
	<main class="mx-auto flex min-h-[70vh] max-w-2xl flex-col justify-center px-4 py-16 sm:px-6">
		<p class="text-sm font-semibold uppercase tracking-wider text-amber-800/90">GetResponse</p>
		<h1 class="font-display mt-3 text-4xl font-semibold tracking-tight text-stone-900">You’re subscribed</h1>
		<p class="mt-4 text-lg text-stone-600">
			Thanks for joining the mailing list. We’ll send updates about Love Power Paws and booth <strong>#6113</strong>{' '}
			at The Shed.
		</p>
		<p class="mt-6 text-sm text-stone-500">
			You can close this tab, or head back to the main page anytime.
		</p>
		<p class="mt-8">
			<a
				href="/"
				class="inline-flex items-center justify-center rounded-xl bg-stone-900 px-5 py-3 text-sm font-semibold text-white shadow-sm transition hover:bg-stone-800 focus:outline-none focus-visible:ring-4 focus-visible:ring-amber-500/35"
			>
				Back to home
			</a>
		</p>
	</main>
</Layout>
