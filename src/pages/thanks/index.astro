---
import Layout from '../../layouts/Layout.astro';
---

<Layout
	title="Thanks for subscribing | Love Power Paws"
	description="You’re on the list for Love Power Paws updates from booth #6113 at The Shed."
>
	<main class="mx-auto flex min-h-[70vh] max-w-2xl flex-col justify-center px-4 py-16 sm:px-6">
		<p class="text-sm font-semibold uppercase tracking-wider text-lp-purple">GetResponse</p>
		<h1 class="font-display mt-3 text-4xl font-semibold tracking-tight text-lp-ink">You’re subscribed</h1>
		<p class="mt-4 text-lg text-lp-slate">
			Thanks for joining the mailing list. We’ll share news about new decor, stickers, magnets, and other booth favorites
			from <strong>#6113</strong> at The Shed.
		</p>
		<p class="mt-6 text-sm text-lp-slate/85">
			You can close this tab, or head back to the main page anytime.
		</p>
		<p class="mt-8">
			<a
				href="/"
				class="inline-flex items-center justify-center rounded-xl bg-lp-ink px-5 py-3 text-sm font-semibold text-white shadow-sm transition hover:bg-lp-slate focus:outline-none focus-visible:ring-4 focus-visible:ring-lp-teal/40"
			>
				Back to home
			</a>
		</p>
	</main>
</Layout>
