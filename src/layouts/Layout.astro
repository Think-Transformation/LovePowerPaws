---
import '../styles/global.css';

type Props = {
	title: string;
	description?: string;
};

const { title, description = 'Love Power Paws at The Shed — booth #6113. Photos, story, and mailing list updates.' } =
	Astro.props;

const canonical = new URL(Astro.url.pathname, Astro.site);
---

<!doctype html>
<html lang="en" class="scroll-smooth">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="theme-color" content="#5cb8aa" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" sizes="any" />
		<meta name="generator" content={Astro.generator} />
		<link rel="canonical" href={canonical.href} />

		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,600;0,9..144,700;1,9..144,600&family=DM+Sans:ital,opsz,wght@0,9..40,400;0,9..40,500;0,9..40,600;0,9..40,700;1,9..40,400&display=swap"
			rel="stylesheet"
		/>

		<title>{title}</title>
		<meta name="description" content={description} />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:url" content={canonical.href} />
		<meta property="og:type" content="website" />
	</head>
	<body class="min-h-screen bg-lp-mint text-lp-ink antialiased font-sans">
		<slot />
	</body>
</html>

<style is:global>
	:root {
		--font-display: 'Fraunces', ui-serif, Georgia, serif;
	}

	.font-display {
		font-family: var(--font-display);
	}
</style>
